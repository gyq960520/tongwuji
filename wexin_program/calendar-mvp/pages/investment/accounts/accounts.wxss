.page {
  padding: 0 32rpx 200rpx;
}

.subtitle {
  font-size: var(--fs-xs);
  color: var(--text-tertiary);
  margin-top: 16rpx;
}

.section-title {
  font-size: var(--fs-2xl);
  font-weight: var(--fw-bold);
  line-height: 1.3;
  margin-top: 28rpx;
}

.section-divider {
  height: 1rpx;
  background: var(--divider);
  margin: 14rpx 0 18rpx;
}

.account-item {
  display: flex;
  align-items: center;
  padding: 28rpx 0;
}
.account-item--hover {
  opacity: 0.6;
}
.account-item__main {
  flex: 1;
  min-width: 0;
}
.account-item__name {
  font-size: var(--fs-lg);
  font-weight: var(--fw-bold);
  color: var(--text-primary);
}
.account-item__meta {
  font-size: var(--fs-sm);
  color: var(--text-tertiary);
  margin-top: 6rpx;
}
.account-item__arrow {
  font-size: var(--fs-base);
  color: var(--text-tertiary);
  margin-left: 16rpx;
}

.divider-soft {
  height: 1rpx;
  background: var(--divider-soft);
}

.empty-state {
  font-size: var(--fs-base);
  color: var(--text-tertiary);
  padding: 60rpx 0;
}

.fab {
  position: fixed;
  right: 48rpx;
  bottom: calc(env(safe-area-inset-bottom) + 96rpx);
  width: 96rpx;
  height: 96rpx;
  border-radius: var(--radius-circle);
  background: var(--text-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}
.fab--hover {
  opacity: 0.7;
}
.fab__icon {
  font-size: var(--fs-2xl);
  color: #FFFFFF;
  line-height: 1;
}
