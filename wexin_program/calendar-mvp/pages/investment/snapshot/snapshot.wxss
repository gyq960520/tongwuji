.page {
  padding: 0 32rpx 220rpx;
}

.snapshot__top {
  font-size: var(--fs-xs);
  color: var(--text-tertiary);
  margin-top: 16rpx;
}

.snapshot__title {
  font-size: var(--fs-2xl);
  font-weight: var(--fw-bold);
  line-height: 1.3;
  margin-top: 28rpx;
  color: var(--text-primary);
}

/* 历史快照标题行：左边标题、右边编辑/删除按钮 */
.snapshot__title-row {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
}
.snapshot__title-actions {
  display: flex;
  gap: 12rpx;
  margin-bottom: 6rpx;  /* 跟 title 的 baseline 对齐 */
}
.snapshot__title-action {
  font-size: var(--fs-sm);
  color: var(--text-secondary);
  padding: 8rpx 22rpx;
  border: 1rpx solid var(--divider);
  border-radius: 999rpx;
  line-height: 1.5;
}
.snapshot__title-action--danger {
  color: var(--danger);
  border-color: var(--danger);
}
.snapshot__title-action--hover { opacity: 0.5; }

.snapshot__rule {
  height: 1rpx;
  background: var(--divider);
  margin: 14rpx 0 18rpx;
}

.snapshot__hint {
  font-size: var(--fs-sm);
  color: var(--text-tertiary);
  margin-bottom: 32rpx;
}

.snapshot__meta-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}
.snapshot__meta {
  font-size: var(--fs-sm);
  color: var(--text-tertiary);
}
.snapshot__config-link {
  font-size: var(--fs-sm);
  color: var(--text-primary);
  padding: 6rpx 16rpx;
  border: 1rpx solid var(--divider);
  border-radius: 999rpx;
}
.snapshot__config-link--hover { opacity: 0.5; }

.snapshot__section {
  margin-top: 72rpx;
}

.snapshot__subtitle {
  font-size: var(--fs-xl);
  font-weight: var(--fw-bold);
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

/* 复盘 */
.snapshot__reflection {
  background: #F8F8F6;
  padding: 28rpx;
  border-radius: 16rpx;
  position: relative;
}
.snapshot__reflection--hover { opacity: 0.7; }
.snapshot__reflection--readonly { background: #FAFAF8; }
.snapshot__reflection--editable {
  padding-right: 64rpx;  /* 给右上角铅笔图标让位 */
}
.snapshot__reflection-content {
  font-size: var(--fs-sm);
  color: var(--text-secondary);
  line-height: 1.6;
  word-wrap: break-word;
  white-space: pre-wrap;
}
.snapshot__reflection-empty {
  font-size: var(--fs-sm);
  color: var(--text-tertiary);
}
.snapshot__reflection-pencil {
  position: absolute;
  top: 28rpx;
  right: 28rpx;
  font-size: var(--fs-lg);
  color: var(--text-tertiary);
  line-height: 1;
}

/* Tab 切换 */
.snapshot__tabs-row {
  display: flex;
  border-bottom: 1rpx solid var(--divider);
  margin-bottom: 18rpx;
}
.snapshot__tab {
  padding: 16rpx 32rpx 16rpx 0;
  margin-right: 32rpx;
  font-size: var(--fs-lg);
  color: var(--text-tertiary);
  position: relative;
}
.snapshot__tab--active {
  color: var(--text-primary);
  font-weight: var(--fw-bold);
}
.snapshot__tab--active::after {
  content: '';
  position: absolute;
  bottom: -1rpx;
  left: 0;
  right: 32rpx;
  height: 3rpx;
  background: var(--text-primary);
}
.snapshot__rate-note {
  font-size: var(--fs-xxs);
  color: var(--text-tertiary);
  padding: 8rpx 0 16rpx;
}

/* 持仓明细标题 + 切换原币种按钮 */
.snapshot__detail-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0 8rpx;
}
.snapshot__detail-title {
  font-size: var(--fs-xl);
  font-weight: var(--fw-bold);
  color: var(--text-primary);
}
.snapshot__detail-toggle {
  font-size: var(--fs-sm);
  color: var(--text-secondary);
  padding: 8rpx 20rpx;
  border: 1rpx solid var(--divider);
  border-radius: 999rpx;
  line-height: 1.4;
}
.snapshot__detail-toggle--hover {
  opacity: 0.5;
}

/* 持仓总览（饼图 + 录入入口）和下方账户明细之间的深色分隔线 */
.snapshot__section-rule {
  height: 2rpx;
  background: var(--text-secondary);
  margin: 12rpx 0 20rpx;
  opacity: 0.5;
}

/* 当前 tab 总金额：放在 tabs-row 和 rateNotes / 饼图之间，放大加粗，整页第一眼看到的就是它
   --fw-bold 项目里是 500（Apple 风格的"加粗"），这里走绝对 700 让金额更突出 */
.snapshot__current-total {
  font-size: var(--fs-3xl);
  font-weight: 700;
  color: var(--text-primary);
  padding: 24rpx 0 16rpx;
  letter-spacing: -0.5rpx;
}

/* 大类占比饼图 */
.snapshot__chart {
  display: flex;
  align-items: center;
  padding: 16rpx 0 36rpx;
}
.snapshot__pie-wrap {
  position: relative;
  width: 220rpx;
  height: 220rpx;
  flex-shrink: 0;
}
.snapshot__pie {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}
.snapshot__pie-hole {
  position: absolute;
  top: 24%; left: 24%;
  width: 52%; height: 52%;
  background: var(--bg);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}
.snapshot__pie-total {
  font-size: var(--fs-sm);
  color: var(--text-primary);
  font-weight: var(--fw-bold);
}
.snapshot__pie-label {
  position: absolute;
  top: 50%;
  left: 50%;
  font-size: 22rpx;
  font-weight: 500;
  white-space: nowrap;
  pointer-events: none;
}
.snapshot__legend {
  flex: 1;
  padding-left: 36rpx;
}
.snapshot__legend-header {
  display: flex;
  align-items: center;
  padding: 4rpx 0 6rpx;
  font-size: var(--fs-xxs);
  color: var(--text-tertiary);
}
.snapshot__legend-label-h {
  flex: 1;
  padding-left: 28rpx;   /* 让位给 dot + 间距 */
}
.snapshot__legend-gap-h {
  width: 50rpx;
  margin-right: 6rpx;
}
.snapshot__legend-target-h {
  width: 70rpx;
  text-align: left;
  margin-right: 14rpx;
}
.snapshot__legend-actual-h {
  width: 70rpx;
  text-align: left;
  margin-right: 14rpx;
}
.snapshot__legend-amount-h {
  width: 90rpx;
  text-align: left;
}
.snapshot__legend-item {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}
.snapshot__legend-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-right: 14rpx;
  flex-shrink: 0;
}
.snapshot__legend-label {
  flex: 1;
  font-size: var(--fs-sm);
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 0;
}
/* 超/低标签列：颜色走 inline style（红=超配、绿=低配），目标列左侧 */
.snapshot__legend-gap {
  width: 50rpx;
  margin-right: 6rpx;
  text-align: left;
  font-size: var(--fs-xxs);
  line-height: 1.3;
}
.snapshot__legend-target {
  width: 70rpx;
  text-align: left;
  font-size: var(--fs-sm);
  color: var(--text-secondary);
  margin-right: 14rpx;
}
.snapshot__legend-percent {
  width: 70rpx;
  text-align: left;
  font-size: var(--fs-sm);
  color: var(--text-secondary);
  margin-right: 14rpx;
}
.snapshot__legend-amount {
  width: 90rpx;
  text-align: left;
  font-size: var(--fs-sm);
  color: var(--text-tertiary);
}

/* 空 */
.snapshot__empty {
  font-size: var(--fs-sm);
  color: var(--text-tertiary);
  padding: 24rpx 0;
}

/* 账户间分隔 */
.snapshot__account-sep {
  height: 1rpx;
  background: var(--divider);
  margin: 28rpx 0;
}

/* 账户头 */
.snapshot__account-head {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}
.snapshot__account-head--hover { opacity: 0.6; }
.snapshot__chev {
  font-size: 20rpx;
  color: var(--text-tertiary);
  margin-right: 12rpx;
  display: inline-block;
  transition: transform 0.2s ease;
  transform-origin: center;
  line-height: 1;
  width: 24rpx;
  text-align: center;
}
.snapshot__chev--collapsed { transform: rotate(-90deg); }
.snapshot__account-name {
  flex: 1;
  min-width: 0;
  font-size: var(--fs-lg);
  font-weight: var(--fw-bold);
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.snapshot__account-sum {
  font-size: var(--fs-lg);
  color: var(--text-primary);
  margin-left: 16rpx;
  font-weight: var(--fw-bold);
}

.snapshot__edit-btn {
  font-size: var(--fs-xs);
  color: var(--text-secondary);
  padding: 8rpx 22rpx;
  border: 1rpx solid var(--divider);
  border-radius: 999rpx;
  line-height: 1.5;
}
.snapshot__edit-btn--hover { opacity: 0.5; }

/* 账户底部操作行：右对齐的两个胶囊按钮 */
.snapshot__account-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  padding: 20rpx 0 4rpx;
}

/* 列头 */
.snapshot__col-header {
  display: flex;
  align-items: center;
  padding: 12rpx 0 8rpx;
  font-size: var(--fs-xxs);
  color: var(--text-tertiary);
  border-bottom: 1rpx solid var(--divider-soft);
}
.snapshot__col-name-h {
  flex: 1;
  padding-left: 36rpx;
}
.snapshot__col-cur-h {
  width: 70rpx;
  text-align: center;
}
.snapshot__col-pct-h {
  width: 70rpx;
  text-align: right;
}
.snapshot__col-rmb-h {
  width: 180rpx;
  text-align: right;
}

/* 大类小标题：用跟明细行一样的列模型，让占比/合计严格对齐到明细列 */
.snapshot__cat-header {
  display: flex;
  align-items: center;
  padding: 16rpx 0 4rpx;
}
.snapshot__cat-name-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
}
.snapshot__cat-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}
.snapshot__cat-name {
  font-size: var(--fs-sm);
  color: var(--text-primary);
  font-weight: var(--fw-bold);
}
.snapshot__cat-pct {
  width: 70rpx;
  text-align: right;
  font-size: var(--fs-sm);
  color: var(--text-primary);
  font-weight: var(--fw-bold);
}
.snapshot__cat-sum {
  width: 180rpx;
  text-align: right;
  font-size: var(--fs-sm);
  color: var(--text-primary);
  font-weight: var(--fw-bold);
}

/* 持仓行（3 列：币种 / 占比 / RMB 金额） */
.snapshot__pos {
  display: flex;
  align-items: center;
  padding: 10rpx 0;
}
.snapshot__pos-name {
  flex: 1;
  font-size: var(--fs-base);
  color: var(--text-secondary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  min-width: 0;
  padding-left: 36rpx;
}
.snapshot__pos-cur {
  width: 70rpx;
  text-align: center;
  font-size: var(--fs-xs);
  color: var(--text-tertiary);
}
.snapshot__pos-pct {
  width: 70rpx;
  text-align: right;
  font-size: var(--fs-sm);
  color: var(--text-secondary);
}
.snapshot__pos-rmb {
  width: 180rpx;
  text-align: right;
  font-size: var(--fs-base);
  color: var(--text-secondary);
}

.snapshot__add-link {
  font-size: var(--fs-sm);
  color: var(--text-primary);
  padding: 20rpx 0 20rpx 36rpx;
}
.snapshot__add-link--hover { opacity: 0.5; }

/* ============== 币种敞口 ============== */
.snapshot__cur-section {
  padding: 8rpx 0 24rpx;
}
.snapshot__cur-title {
  font-size: var(--fs-sm);
  color: var(--text-tertiary);
  margin-bottom: 14rpx;
}
.snapshot__cur-bar {
  width: 100%;
  height: 16rpx;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}
.snapshot__cur-legend {
  display: flex;
  flex-direction: column;
}
.snapshot__cur-row {
  display: flex;
  align-items: center;
  padding: 6rpx 0;
}
.snapshot__cur-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  margin-right: 14rpx;
  flex-shrink: 0;
}
.snapshot__cur-code {
  width: 64rpx;
  font-size: var(--fs-sm);
  color: var(--text-primary);
  font-weight: var(--fw-bold);
}
.snapshot__cur-label {
  flex: 1;
  min-width: 0;
  font-size: var(--fs-sm);
  color: var(--text-secondary);
}
.snapshot__cur-percent {
  width: 80rpx;
  text-align: right;
  font-size: var(--fs-sm);
  color: var(--text-secondary);
  margin-right: 16rpx;
}
.snapshot__cur-amount {
  min-width: 180rpx;
  text-align: right;
  font-size: var(--fs-sm);
  color: var(--text-tertiary);
}

.snapshot__primary-btn {
  background: var(--text-primary);
  color: #FFFFFF;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: var(--fs-lg);
  font-weight: var(--fw-bold);
  border-radius: 24rpx;
  margin-top: 32rpx;
}
.snapshot__btn--hover { opacity: 0.7; }
.snapshot__close-btn {
  font-size: var(--fs-lg);
  color: var(--danger);
  text-align: center;
  padding: 32rpx 0;
  margin-top: 60rpx;
}


/* ============== 期数头 ============== */
.period-header {
  display: flex;
  align-items: center;
  background: #F8F8F6;
  border-radius: 16rpx;
  padding: 20rpx 28rpx;
  margin-top: 20rpx;
}
.period-header--hover { opacity: 0.7; }
.period-header__left {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}
.period-header__title {
  font-size: var(--fs-lg);
  font-weight: var(--fw-bold);
  color: var(--text-primary);
  line-height: 1.3;
}
.period-header__sub {
  margin-top: 6rpx;
  font-size: var(--fs-xs);
  color: var(--text-tertiary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.period-header__arrow {
  font-size: var(--fs-lg);
  color: var(--text-tertiary);
  margin-left: 16rpx;
  line-height: 1;
}

/* ============== 期数选择底部弹窗 ============== */
.picker-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 10000;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}
.picker-panel {
  width: 100%;
  background: #FFFFFF;
  border-top-left-radius: 28rpx;
  border-top-right-radius: 28rpx;
  padding: 16rpx 32rpx 40rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}
.picker-grip {
  width: 80rpx;
  height: 8rpx;
  background: #DDDDDD;
  border-radius: 4rpx;
  margin: 0 auto 20rpx;
}
.picker-title {
  font-size: var(--fs-xl);
  font-weight: var(--fw-bold);
  color: var(--text-primary);
  text-align: center;
}
.picker-subtitle {
  font-size: var(--fs-xs);
  color: var(--text-tertiary);
  text-align: center;
  margin-top: 8rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid var(--divider);
}
.picker-list {
  flex: 1;
  margin-top: 8rpx;
}
.picker-item {
  display: flex;
  align-items: center;
  padding: 24rpx 8rpx;
  border-bottom: 1rpx solid var(--divider-soft);
}
.picker-item--hover { background: #F4F4F2; }
.picker-item--active {
  background: #FAFAF8;
}
.picker-item__main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}
.picker-item__title-row {
  display: flex;
  align-items: center;
}
.picker-item__title {
  font-size: var(--fs-lg);
  font-weight: var(--fw-bold);
  color: var(--text-primary);
  line-height: 1.3;
}
.picker-item__open-tag {
  font-size: var(--fs-xxs);
  color: #FFFFFF;
  background: var(--text-primary);
  border-radius: 999rpx;
  padding: 2rpx 14rpx;
  margin-left: 14rpx;
  line-height: 1.5;
}
.picker-item__sub {
  margin-top: 6rpx;
  font-size: var(--fs-xs);
  color: var(--text-tertiary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.picker-item__check {
  font-size: var(--fs-xl);
  color: var(--text-primary);
  margin-left: 16rpx;
  line-height: 1;
}
.picker-item__arrow {
  font-size: var(--fs-xl);
  color: var(--text-tertiary);
  margin-left: 16rpx;
  line-height: 1;
}
