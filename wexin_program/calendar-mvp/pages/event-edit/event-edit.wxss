.edit {
  padding-top: 16rpx;
  padding-bottom: 60rpx;
}

.edit__row {
  display: flex;
  align-items: center;
  padding: 32rpx 0;
  margin-left: 48rpx;
  margin-right: -48rpx;
  padding-right: 48rpx;
  border-bottom: 1rpx solid var(--divider-soft);
  box-sizing: border-box;
}
.edit__row:first-child {
  margin-left: 0;
  padding-left: 0;
  margin-right: 0;
  padding-right: 0;
}
.edit__row--picker {
  justify-content: space-between;
}
.edit__row--type {
  align-items: flex-start;
  flex-direction: column;
}

.edit__title {
  font-size: var(--fs-xl);
  font-weight: var(--fw-bold);
  color: var(--text-primary);
  width: 100%;
}
.edit__placeholder {
  color: var(--text-tertiary);
}

.edit__label {
  font-size: var(--fs-base);
}
.edit__value {
  font-size: var(--fs-base);
  color: var(--text-secondary);
}

.edit__type-list {
  display: flex;
  flex-wrap: wrap;
  margin-top: 20rpx;
}
.edit__type {
  height: 64rpx;
  line-height: 64rpx;
  padding: 0 24rpx;
  border-radius: var(--radius-pill);
  font-size: var(--fs-sm);
  color: var(--text-secondary);
  border: 1rpx solid var(--divider);
  background: transparent;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  display: flex;
  align-items: center;
}
.edit__type-emoji {
  font-size: var(--fs-xs);
  margin-right: 8rpx;
  line-height: 1;
}
.edit__type-label {
  font-size: var(--fs-sm);
  line-height: 1;
}
.edit__type--active {
  background: var(--text-primary);
  color: var(--bg);
  border-color: var(--text-primary);
}
.edit__type--active .edit__type-label {
  color: var(--bg);
}

.edit__time-picker {
  flex: 1;
}
.edit__time-inner {
  display: flex;
  justify-content: space-between;
}
.edit__clear {
  margin-left: 24rpx;
  font-size: var(--fs-xs);
  padding: 8rpx 12rpx;
}

.edit__note {
  font-size: var(--fs-base);
  width: 100%;
  height: 200rpx;
  color: var(--text-primary);
}

.edit__actions {
  margin-top: 60rpx;
  display: flex;
  align-items: center;
}
.edit__save {
  flex: 2;
  background: var(--text-primary);
  color: var(--bg);
  border-radius: var(--radius-button);
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  font-size: var(--fs-md);
  font-weight: var(--fw-bold);
}
.edit__delete {
  flex: 1;
  color: var(--danger);
  font-size: var(--fs-md);
  text-align: center;
  height: 88rpx;
  line-height: 88rpx;
  margin-right: 24rpx;
}
.edit__actions--two .edit__save {
  flex: 2;
}
