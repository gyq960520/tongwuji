<view class="page edit">
  <view class="edit__row">
    <input
      class="edit__title"
      placeholder="做点什么"
      placeholder-class="edit__placeholder"
      value="{{title}}"
      bindinput="onTitleInput"
      maxlength="40" />
  </view>

  <view class="edit__row edit__row--type">
    <view class="edit__label text-secondary">分类</view>
    <view class="edit__type-list">
      <view
        wx:for="{{typeOptions}}"
        wx:key="key"
        class="edit__type {{type === item.key ? 'edit__type--active' : ''}}"
        data-key="{{item.key}}"
        bindtap="onSelectType">
        <text class="edit__type-emoji">{{item.emoji}}</text>
        <text class="edit__type-label">{{item.label}}</text>
      </view>
      <view
        wx:for="{{customCategories}}"
        wx:for-item="cat"
        wx:key="_id"
        class="edit__type {{type === cat._id ? 'edit__type--active' : ''}}"
        data-key="{{cat._id}}"
        bindtap="onSelectType">
        <text class="edit__type-emoji">{{cat.emoji}}</text>
        <text class="edit__type-label">{{cat.name}}</text>
      </view>
      <view wx:if="{{canAddCustom}}" class="edit__type edit__type--add" bindtap="onAddCustom">
        <text class="edit__type-emoji edit__type-emoji--plus">+</text>
        <text class="edit__type-label">自定义</text>
      </view>
    </view>
  </view>

  <picker mode="multiSelector"
          range="{{pickerRange}}"
          value="{{pickerValue}}"
          bindcolumnchange="onPickDateColumnChange"
          bindchange="onPickDate">
    <view class="edit__row edit__row--picker">
      <text class="edit__label text-secondary">日期</text>
      <text class="edit__value tnum">{{dateLabel || '请选择'}} ›</text>
    </view>
  </picker>

  <view class="edit__row edit__row--picker">
    <picker mode="time" value="{{time}}" bindchange="onPickTime" class="edit__time-picker">
      <view class="edit__time-inner">
        <text class="edit__label text-secondary">时间</text>
        <text class="edit__value tnum">{{time ? time + ' ›' : '全天 ›'}}</text>
      </view>
    </picker>
    <text wx:if="{{time}}" class="edit__clear text-tertiary" catchtap="onClearTime">清除</text>
  </view>

  <picker mode="selector" range="{{recurrenceLabels}}" value="{{recurrenceIndex}}" bindchange="onPickRecurrence">
    <view class="edit__row edit__row--picker">
      <text class="edit__label text-secondary">重复</text>
      <text class="edit__value tnum">{{recurrenceLabels[recurrenceIndex]}} ›</text>
    </view>
  </picker>

  <view wx:if="{{recurrenceIndex > 0}}" class="edit__row edit__row--picker">
    <picker mode="date" value="{{recurrenceUntil}}" bindchange="onPickRecurrenceUntil" class="edit__time-picker">
      <view class="edit__time-inner">
        <text class="edit__label text-secondary">结束于</text>
        <text class="edit__value tnum">{{recurrenceUntil ? recurrenceUntil + ' ›' : '永不 ›'}}</text>
      </view>
    </picker>
    <text wx:if="{{recurrenceUntil}}" class="edit__clear text-tertiary" catchtap="onClearRecurrenceUntil">清除</text>
  </view>

  <picker mode="selector" range="{{reminderLabels}}" value="{{reminderIndex}}" bindchange="onPickReminder">
    <view class="edit__row edit__row--picker">
      <text class="edit__label text-secondary">微信提醒</text>
      <text class="edit__value tnum">{{reminderLabels[reminderIndex]}} ›</text>
    </view>
  </picker>

  <view class="edit__row edit__row--picker">
    <text class="edit__label text-secondary">共享对方</text>
    <switch checked="{{isShared}}" bindchange="onToggleShare" color="#1D1D1F" />
  </view>

  <view class="edit__row">
    <textarea
      class="edit__note"
      placeholder="备注（可选）"
      placeholder-class="edit__placeholder"
      value="{{note}}"
      bindinput="onNoteInput"
      maxlength="-1" />
  </view>

  <view class="edit__actions {{isEdit ? 'edit__actions--two' : ''}}">
    <view wx:if="{{isEdit}}" class="edit__delete" bindtap="onDelete">删除</view>
    <view class="edit__save" bindtap="onSave">保存</view>
  </view>
</view>

<!-- 新建自定义分类 sheet -->
<view wx:if="{{showSheet}}" class="cat-sheet__mask" bindtap="onCloseSheet" catchtouchmove="onSheetCatchTouchMove">
  <view class="cat-sheet" catchtap="onSheetCatchTap">
    <view class="cat-sheet__grip"></view>
    <view class="cat-sheet__title">新建自定义分类</view>

    <view class="cat-sheet__field">
      <text class="cat-sheet__label text-secondary">名字</text>
      <input
        class="cat-sheet__input"
        placeholder="2-6 个字"
        placeholder-class="cat-sheet__placeholder"
        maxlength="-1"
        value="{{newCategoryName}}"
        bindinput="onSheetNameInput" />
    </view>

    <view class="cat-sheet__field">
      <text class="cat-sheet__label text-secondary">Emoji</text>
      <text class="cat-sheet__preview">{{newCategoryEmoji || '—'}}</text>
    </view>

    <scroll-view scroll-y="true" class="cat-sheet__emoji-scroll">
      <block wx:for="{{presetEmojiGroups}}" wx:for-item="group" wx:key="label">
        <view class="cat-sheet__group">
          <text class="cat-sheet__group-label text-tertiary">{{group.label}}</text>
          <view class="cat-sheet__emoji-row">
            <view
              wx:for="{{group.emojis}}"
              wx:for-item="em"
              wx:key="*this"
              class="cat-sheet__emoji-chip {{newCategoryEmoji === em ? 'cat-sheet__emoji-chip--active' : ''}}"
              data-emoji="{{em}}"
              bindtap="onSelectPresetEmoji">{{em}}</view>
          </view>
        </view>
      </block>
    </scroll-view>

    <view class="cat-sheet__field">
      <text class="cat-sheet__label text-secondary">或输入</text>
      <input
        class="cat-sheet__input"
        placeholder="自由输入其他 emoji"
        placeholder-class="cat-sheet__placeholder"
        value="{{newCategoryEmoji}}"
        bindinput="onSheetEmojiInput" />
    </view>

    <view class="cat-sheet__actions">
      <view class="cat-sheet__cancel" bindtap="onCloseSheet">取消</view>
      <view class="cat-sheet__confirm {{canConfirmSheet ? '' : 'cat-sheet__confirm--disabled'}}" bindtap="onConfirmSheet">确定</view>
    </view>
  </view>
</view>
