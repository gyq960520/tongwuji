.mgr {
  padding-top: 24rpx;
}
.mgr__top {
  font-size: var(--fs-xs);
  margin-bottom: 32rpx;
  line-height: 1.6;
}
.mgr__empty {
  font-size: var(--fs-sm);
  color: var(--text-empty);
  text-align: center;
  padding: 60rpx 0;
}
.mgr__item {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--divider-soft);
}
.mgr__emoji {
  font-size: var(--fs-xl);
  margin-right: 24rpx;
}
.mgr__name {
  flex: 1;
  font-size: var(--fs-base);
  color: var(--text-primary);
}
.mgr__actions {
  display: flex;
  gap: 16rpx;
}
.mgr__btn {
  font-size: var(--fs-sm);
  padding: 8rpx 20rpx;
  border: 1rpx solid var(--divider);
  border-radius: var(--radius-pill);
  color: var(--text-secondary);
}
.mgr__btn--danger {
  color: var(--danger);
  border-color: var(--danger);
}
.mgr__btn--hover {
  opacity: 0.6;
}
.mgr__add {
  margin-top: 40rpx;
  height: 88rpx;
  line-height: 86rpx;
  text-align: center;
  font-size: var(--fs-base);
  color: var(--text-primary);
  background: var(--bg);
  border: 1rpx dashed var(--divider);
  border-radius: var(--radius-button);
}
.mgr__add--hover {
  opacity: 0.6;
}
.mgr__limit {
  margin-top: 40rpx;
  text-align: center;
  font-size: var(--fs-xs);
}

/* ===== 自定义分类 sheet（与 event-edit.wxss 一致；mini-program wxss 是 page-scoped 所以各页面各维护一份） ===== */
.cat-sheet__mask {
  position: fixed;
  left: 0; right: 0; top: 0; bottom: 0;
  background: rgba(0,0,0,0.4);
  z-index: 100;
  display: flex;
  align-items: flex-end;
}
.cat-sheet {
  width: 100%;
  background: var(--bg);
  border-top-left-radius: 24rpx;
  border-top-right-radius: 24rpx;
  padding: 16rpx 48rpx 60rpx;
  max-height: 80vh;
  display: flex;
  flex-direction: column;
}
.cat-sheet__grip {
  width: 64rpx;
  height: 6rpx;
  border-radius: 3rpx;
  background: var(--divider);
  margin: 0 auto 16rpx;
}
.cat-sheet__title {
  font-size: var(--fs-lg);
  font-weight: var(--fw-bold);
  color: var(--text-primary);
  margin-bottom: 24rpx;
}
.cat-sheet__field {
  display: flex;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--divider-soft);
}
.cat-sheet__label {
  width: 120rpx;
  font-size: var(--fs-sm);
}
.cat-sheet__input {
  flex: 1;
  font-size: var(--fs-base);
  color: var(--text-primary);
}
.cat-sheet__placeholder {
  color: var(--text-tertiary);
}
.cat-sheet__preview {
  flex: 1;
  font-size: var(--fs-xl);
  color: var(--text-primary);
}
.cat-sheet__emoji-scroll {
  flex: 1;
  margin: 16rpx 0;
  max-height: 480rpx;
}
.cat-sheet__group {
  margin-bottom: 20rpx;
}
.cat-sheet__group-label {
  font-size: var(--fs-xxs);
  margin-bottom: 12rpx;
}
.cat-sheet__emoji-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}
.cat-sheet__emoji-chip {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  border: 1rpx solid var(--divider);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: var(--fs-xl);
  background: transparent;
}
.cat-sheet__emoji-chip--active {
  border-color: var(--text-primary);
  border-width: 2rpx;
}
.cat-sheet__actions {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}
.cat-sheet__cancel,
.cat-sheet__confirm {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: var(--radius-button);
  font-size: var(--fs-md);
  font-weight: var(--fw-bold);
}
.cat-sheet__cancel {
  background: transparent;
  color: var(--text-secondary);
  border: 1rpx solid var(--divider);
}
.cat-sheet__confirm {
  background: var(--text-primary);
  color: var(--bg);
}
.cat-sheet__confirm--disabled {
  background: var(--text-disabled);
}
