<view class="page timeline">
  <view class="timeline__top tnum">{{todayLabel}}</view>

  <!-- 周期事件续订提示：每月一次的"续命"动作（一次性模板每次发送都要消耗一张授权票） -->
  <view wx:if="{{renewList.length > 0}}" class="timeline__renew">
    <block wx:if="{{renewList.length <= 3 || renewExpanded}}">
      <view wx:if="{{renewList.length > 1}}" class="timeline__renew-summary">下次提醒未开启</view>
      <block wx:for="{{renewList}}" wx:key="eventId">
        <view class="timeline__renew-row">
          <view class="timeline__renew-row-main">
            <text class="timeline__renew-emoji">{{item.emoji}}</text>
            <view class="timeline__renew-text">
              <view class="timeline__renew-title">{{item.title}}</view>
              <view class="timeline__renew-sub tnum">下次 {{item.nextLabel}}</view>
            </view>
          </view>
          <view class="timeline__renew-btn" catchtap="onTapRenew" data-item="{{item}}" hover-class="timeline__renew-btn--hover">续订</view>
        </view>
      </block>
      <view wx:if="{{renewList.length > 3}}" class="timeline__renew-toggle" bindtap="onToggleRenewExpand">收起</view>
    </block>
    <view wx:else class="timeline__renew-row timeline__renew-row--collapsed" bindtap="onToggleRenewExpand">
      <view class="timeline__renew-row-main">
        <text class="timeline__renew-emoji">⚠️</text>
        <view class="timeline__renew-text">
          <view class="timeline__renew-title">{{renewList.length}} 个周期提醒未开启</view>
          <view class="timeline__renew-sub">点击展开续订</view>
        </view>
      </view>
      <view class="timeline__renew-toggle">展开 ›</view>
    </view>
  </view>

  <!-- 今天 -->
  <view class="timeline__section">
    <view class="timeline__section-title">今天</view>
    <view class="timeline__section-rule"></view>
    <view wx:if="{{todayEvents.length === 0}}" class="timeline__empty">今天没有安排</view>
    <view wx:else>
      <block wx:for="{{todayEvents}}" wx:key="id">
        <view wx:if="{{index > 0}}" class="event-divider"></view>
        <event-item event="{{item}}" customCategories="{{customCategories}}" bind:select="onTapEvent" />
      </block>
    </view>
  </view>

  <!-- 本周 -->
  <view class="timeline__section">
    <view class="timeline__section-title">本周</view>
    <view class="timeline__section-rule"></view>
    <view wx:if="{{weekGroups.length === 0}}" class="timeline__empty">本周没有其他安排</view>
    <view wx:else>
      <block wx:for="{{weekGroups}}" wx:for-item="group" wx:for-index="gi" wx:key="date">
        <view wx:if="{{gi > 0}}" class="group-rule"></view>
        <view class="timeline__group-label tnum">{{group.label}}</view>
        <block wx:for="{{group.events}}" wx:for-item="ev" wx:for-index="ei" wx:key="id">
          <view wx:if="{{ei > 0}}" class="event-divider"></view>
          <event-item event="{{ev}}" customCategories="{{customCategories}}" bind:select="onTapEvent" />
        </block>
      </block>
    </view>
  </view>

  <!-- 未来 -->
  <view class="timeline__section">
    <view class="timeline__section-title">未来</view>
    <view class="timeline__section-rule"></view>
    <view wx:if="{{futureGroups.length === 0}}" class="timeline__empty">近 90 天没有事件</view>
    <view wx:else>
      <block wx:for="{{futureGroups}}" wx:for-item="group" wx:for-index="gi" wx:key="date">
        <view wx:if="{{gi > 0}}" class="group-rule"></view>
        <view class="timeline__group-label tnum">{{group.label}}</view>
        <block wx:for="{{group.events}}" wx:for-item="ev" wx:for-index="ei" wx:key="id">
          <view wx:if="{{ei > 0}}" class="event-divider"></view>
          <event-item event="{{ev}}" customCategories="{{customCategories}}" bind:select="onTapEvent" />
        </block>
      </block>
    </view>
  </view>

  <view class="timeline__fab" bindtap="onAdd" hover-class="timeline__fab--hover">
    <text class="timeline__fab-icon">+</text>
  </view>
</view>
